<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/movieListFragment">

    <fragment
        android:id="@+id/movieListFragment"
        android:name="com.docenlineacolombia.movielibrary.ui.list.MovieListFragment"
        android:label="Lista de películas"
        tools:layout="@layout/fragment_movie_list">
        <!-- Acción a detalle, inicialmente con Bundle manual. Luego usar Safe Args. -->
        <action
            android:id="@+id/action_movieListFragment_to_movieDetailFragment"
            app:destination="@id/movieDetailFragment" />
        <action
            android:id="@+id/action_movieListFragment_to_movieEditFragment"
            app:destination="@id/movieEditFragment" />
    </fragment>

    <fragment
        android:id="@+id/movieDetailFragment"
        android:name="com.docenlineacolombia.movielibrary.ui.detail.MovieDetailFragment"
        android:label="Detalle película"
        tools:layout="@layout/fragment_movie_detail">
        <action
            android:id="@+id/action_movieDetailFragment_to_movieEditFragment"
            app:destination="@id/movieEditFragment" />
    </fragment>

    <fragment
        android:id="@+id/movieEditFragment"
        android:name="com.docenlineacolombia.movielibrary.ui.edit.MovieEditFragment"
        android:label="Editar película"
        tools:layout="@layout/fragment_movie_edit" />

</navigation>
